# ============================================
# MyPixelPage — Environment Variables
# Copy this to apps/web/.env.local and fill in values.
# That is the ONLY env file needed.
# ============================================

# Database (Prisma + SQLite)
DATABASE_URL="file:./dev.db"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-change-me
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth (optional) — https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_ENABLED=false

# Google OAuth (optional) — https://console.cloud.google.com
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_ENABLED=false

# Creem Payment (Server-side)
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_STARTER_PRODUCT_ID=
CREEM_PRO_PRODUCT_ID=

# Creem Payment (Client-side — must be NEXT_PUBLIC_)
NEXT_PUBLIC_CREEM_STARTER_PRODUCT_ID=
NEXT_PUBLIC_CREEM_PRO_PRODUCT_ID=

# Supabase (optional — only if using Supabase storage)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Cron
CRON_SECRET=change_me
